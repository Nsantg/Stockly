DATABASE_HOST=postgres
DATABASE_PORT=5432
DATABASE_USER=stockly
DATABASE_PASSWORD=stockly_secret_2024
DATABASE_NAME=stockly_db
# Poner en "true" solo para conectarte desde tu máquina a la URL EXTERNA de la
# base de datos de Render (requiere SSL). Dejar "false"/sin definir en local y en Render.
DATABASE_SSL=false

# NextAuth
# PRODUCCIÓN: reemplazar con un valor aleatorio largo antes de desplegar.
# Generar con: openssl rand -base64 32
# El valor de ejemplo NUNCA debe usarse en Render ni en ningún entorno real.
NEXTAUTH_SECRET=stockly-super-secret-nextauth-key-dev-2024-change-in-prod
NEXTAUTH_URL=http://localhost:3000

# Cloudinary
CLOUDINARY_CLOUD_NAME=tu_cloud_name
CLOUDINARY_API_KEY=tu_api_key
CLOUDINARY_API_SECRET=tu_api_secret

# Aplicación
NODE_ENV=development
PORT=3000

# Intervalo de broadcast periódico de alertas por WebSocket (en milisegundos).
# Cubre vencimientos que cambian con el tiempo sin que haya movimientos.
# Valor por defecto si no se define: 900000 (15 minutos).
ALERTS_BROADCAST_INTERVAL_MS=900000
