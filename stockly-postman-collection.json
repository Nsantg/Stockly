          "request": { "method": "GET", "header": [], "url": { "raw": "http://localhost:3000/api/v1/categories/00000000-0000-0000-0000-000000000000", "protocol": "http", "host": ["localhost"], "port": "3000", "path": ["api", "v1", "categories", "00000000-0000-0000-0000-000000000000"] } }
