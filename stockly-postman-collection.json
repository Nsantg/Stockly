          "name": "Obtener Categoria por ID",
          "request": { "method": "GET", "header": [], "url": { "raw": "http://localhost:3000/api/v1/categories/{{category_id}}", "protocol": "http", "host": ["localhost"], "port": "3000", "path": ["api", "v1", "categories", "{{category_id}}"] } }
        },
        {
          "name": "Actualizar Categoria",
          "request": {
            "method": "PUT", "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"Electroterapia Avanzada\",\n  \"requiresRefrigeration\": false\n}", "options": { "raw": { "language": "json" } } },
            "url": { "raw": "http://localhost:3000/api/v1/categories/{{category_id}}", "protocol": "http", "host": ["localhost"], "port": "3000", "path": ["api", "v1", "categories", "{{category_id}}"] }
          }
        },
