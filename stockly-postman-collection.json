          "name": "Subcategorias de una Categoria",
          "request": { "method": "GET", "header": [], "url": { "raw": "http://localhost:3000/api/v1/categories/{{category_id}}/subcategories", "protocol": "http", "host": ["localhost"], "port": "3000", "path": ["api", "v1", "categories", "{{category_id}}", "subcategories"] } }
        },
        {
          "name": "Eliminar Categoria",
          "request": { "method": "DELETE", "header": [], "url": { "raw": "http://localhost:3000/api/v1/categories/{{category_id}}", "protocol": "http", "host": ["localhost"], "port": "3000", "path": ["api", "v1", "categories", "{{category_id}}"] } }
        },
