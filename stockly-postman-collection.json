{
  "info": {
    "name": "Stockly API",
    "_postman_id": "stockly-api-collection-v1",
    "description": "Coleccion completa de endpoints para Stockly. Flujo de inicio: 1) Obtener CSRF Token, 2) Login, 3) Usar el resto de endpoints.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url", "value": "http://localhost:3000", "type": "string" },
    { "key": "csrfToken", "value": "", "type": "string" },
    { "key": "category_id", "value": "", "type": "string" },
    { "key": "subcategory_id", "value": "", "type": "string" },
    { "key": "product_id", "value": "", "type": "string" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "1. Obtener CSRF Token",
          "event": [{ "listen": "test", "script": { "exec": ["const json = pm.response.json();", "pm.collectionVariables.set('csrfToken', json.csrfToken);", "console.log('CSRF Token guardado:', json.csrfToken);"], "type": "text/javascript" } }],
          "request": {
            "method": "GET", "header": [],
            "url": { "raw": "http://localhost:3000/api/auth/csrf", "protocol": "http", "host": ["localhost"], "port": "3000", "path": ["api", "auth", "csrf"] }
          }
        },
        {
          "name": "2. Login",
          "event": [{ "listen": "test", "script": { "exec": ["if (pm.response.code === 200) { console.log('Login exitoso.'); } else { console.error('Login fallido:', pm.response.text()); }"], "type": "text/javascript" } }],
          "request": {
            "method": "POST", "header": [],
            "body": { "mode": "urlencoded", "urlencoded": [{ "key": "csrfToken", "value": "{{csrfToken}}", "type": "text" }, { "key": "email", "value": "admin@stockly.com", "type": "text" }, { "key": "password", "value": "admin123", "type": "text" }, { "key": "redirect", "value": "false", "type": "text" }, { "key": "json", "value": "true", "type": "text" }] },
            "url": { "raw": "http://localhost:3000/api/auth/callback/credentials", "protocol": "http", "host": ["localhost"], "port": "3000", "path": ["api", "auth", "callback", "credentials"] }
          }
        },
        {
          "name": "3. Ver Sesion Activa",
          "request": { "method": "GET", "header": [], "url": { "raw": "http://localhost:3000/api/auth/session", "protocol": "http", "host": ["localhost"], "port": "3000", "path": ["api", "auth", "session"] } }
        },
        {
          "name": "4. Logout",
          "request": {
            "method": "POST", "header": [],
            "body": { "mode": "urlencoded", "urlencoded": [{ "key": "csrfToken", "value": "{{csrfToken}}", "type": "text" }] },
            "url": { "raw": "http://localhost:3000/api/auth/signout", "protocol": "http", "host": ["localhost"], "port": "3000", "path": ["api", "auth", "signout"] }
          }
        }
      ]
    },
    {
