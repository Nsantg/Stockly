{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "module": "commonjs",
    "moduleResolution": "node",
    "noEmit": false,
    "outDir": "./dist",
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true
  },
  "include": ["server.ts", "src/**/*.ts", "types/**/*.d.ts"],
  "exclude": ["node_modules", ".next", "src/app/**/*.ts", "src/app/**/*.tsx"]
}
